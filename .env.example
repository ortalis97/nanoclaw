# NanoClaw Environment Configuration
# Copy this file to .env and fill in your values before starting.
#
# Usage:
#   cp .env.example .env
#   chmod 600 .env
#   nano .env   # fill in your API key

# --- Bot Identity ---
ASSISTANT_NAME=Alfred
# Optional: Hebrew name for the assistant — enables triggering with Hebrew mentions
# (e.g. "אלפרד" or "@אלפרד" anywhere in a message, not just at the start)
ASSISTANT_HEBREW_NAME=אלפרד
# true  = the bot has its own dedicated WhatsApp number (e.g. an eSIM)
# false = the bot shares a number with a human (limits some features)
ASSISTANT_HAS_OWN_NUMBER=true

# --- Authentication (fill in ONE of the following) ---

# Option 1: Anthropic API key (most common)
# ANTHROPIC_API_KEY=sk-ant-...

# Option 2: Claude Code OAuth token
# CLAUDE_CODE_OAUTH_TOKEN=...

# Option 3: Custom endpoint (e.g., proxy, Bedrock, Vertex)
# ANTHROPIC_BASE_URL=https://...
# ANTHROPIC_AUTH_TOKEN=...

# --- Memory Tuning for Oracle Cloud Always Free VM (1GB RAM) ---
#
# Each agent container uses ~300–500MB with Chromium + Claude Code.
# On 1GB RAM, only one container can run safely at a time.
#
# MAX_CONCURRENT_CONTAINERS=1  → only one Docker container at a time
# CONTAINER_TIMEOUT=600000     → 10 min max (down from default 30 min)
# IDLE_TIMEOUT=300000          → 5 min idle before container is killed
MAX_CONCURRENT_CONTAINERS=1
CONTAINER_TIMEOUT=600000
IDLE_TIMEOUT=300000

# --- Timezone ---
# IANA timezone name used by the task scheduler (cron-parser) for reminders and
# scheduled jobs. The VM runs UTC by default; set this to get local fire times.
TZ=Asia/Jerusalem

# --- Sender Allowlist ---
# Comma-separated WhatsApp JIDs allowed to interact with Alfred.
# DMs: only these senders get responses.
# Groups: Alfred joins any group where at least one allowed sender is a member.
# Leave empty to allow ALL senders (no filtering).
# ALLOWED_SENDERS=972553083455@s.whatsapp.net,972548183824@s.whatsapp.net
ALLOWED_SENDERS=

# --- GitHub Integration ---
# Fine-grained Personal Access Token for Alfred to create GitHub Issues.
# Scope: Issues: Read & Write on ortalis97/nanoclaw only.
# Generate at: https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=

# --- Agent Model ---
# Claude model used by agent containers. Leave unset to use the SDK default (claude-sonnet).
# Set to a cheaper model to reduce API cost:
#   claude-haiku-4-5-20251001  → ~5–10x cheaper than Sonnet, good for simple tasks
#   claude-sonnet-4-6          → default, best balance of capability and cost
# AGENT_MODEL=claude-haiku-4-5-20251001

# --- Logging ---
LOG_LEVEL=info
